# Environment Configuration
# Copy this file to .env and fill in your values

# ─── AI Summarization (Required) ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── LinkedIn Automation (Required for LinkedIn posting) ──────────────────────
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# ─── GitHub Repository ────────────────────────────────────────────────────────
GITHUB_REPO_NAME=ai-weekly-monitor
GITHUB_USERNAME=harsha3358

# ─── Dashboard Settings ───────────────────────────────────────────────────────
PORT=3000

# ─── Scheduler Settings ───────────────────────────────────────────────────────
# Day: 1=Monday, Hour in 24h format, Timezone (IANA format)
MONITOR_DAY=1
MONITOR_HOUR=9
MONITOR_MINUTE=0
MONITOR_TZ=Asia/Kolkata
